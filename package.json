{
  "name": "tarot-trainer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5175 --strictPort",
    "dev:server": "tsx watch server/index.ts",
    "download-cards": "tsx scripts/download-rider-waite.ts",
    "validate:cards": "node scripts/validate-card-assets.mjs",
    "serve:api": "tsx server/index.ts",
    "validate:meanings": "tsx scripts/validate-tarot-meanings.ts",
    "validate:concepts": "tsx scripts/validate-concepts.ts",
    "validate:graph": "tsx scripts/validate-concept-graph.ts",
    "validate:tarot": "tsx scripts/validate-tarot-meanings.ts",
    "test:ai-quality": "tsx scripts/test-ai-quality.ts",
    "test:ai-regression": "tsx scripts/test-ai-regression.ts",
    "test:graph-only": "tsx scripts/test-graph-only.ts",
    "report:feedback-composer": "tsx scripts/report-feedback-composer-performance.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@supabase/supabase-js": "^2.48.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "dotenv": "^16.4.7",
    "hono": "^4.6.16",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vercel/node": "^5.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0"
  }
}
